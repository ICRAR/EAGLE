{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "node",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "noImplicitAny": false,
    "ignoreDeprecations": "6.0",
    "types": ["@playwright/test", "node", "jquery"]
  },
  "include": [
    "**/*.ts",
    "*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
